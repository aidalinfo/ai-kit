{
  "name": "@ai_kit/core",
  "version": "1.5.0",
  "description": "",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['dist','tsconfig.build.tsbuildinfo'].forEach(p=>fs.rmSync(p,{recursive:true,force:true}));\"",
    "build": "pnpm run clean && tsc -p tsconfig.build.json",
    "prepare": "pnpm run build",
    "test": "vitest run"
  },
  "keywords": [
    "ai",
    "workflow",
    "agent",
    "orchestration",
    "telemetry"
  ],
  "author": "aidalinfo",
  "license": "ISC",
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@ai-sdk/openai": "3.0.51",
    "@ai-sdk/openai-compatible": "2.0.40",
    "@ai-sdk/provider": "^3.0.0",
    "@ai-sdk/provider-utils": "^4.0.23",
    "@opentelemetry/api": "^1.9.0",
    "@toon-format/toon": "^0.9.0",
    "@types/node": "^24.5.2",
    "ai": "6.0.149",
    "mem0ai": "^3.0.6",
    "pg": "^8.16.3",
    "zod": "^4.1.12"
  },
  "peerDependencies": {
    "@ai_kit/workflow-world": ">=0.1.0 <1",
    "@langfuse/otel": "^5.4.1",
    "@opentelemetry/sdk-trace-node": "^2.2.0"
  },
  "peerDependenciesMeta": {
    "@ai_kit/workflow-world": {
      "optional": true
    },
    "@langfuse/otel": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-node": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^1.1.48",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "@types/pg": "^8.15.6",
    "typescript": "^5.9.2",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}
